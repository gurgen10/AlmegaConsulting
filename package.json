    "react-colorful": "^5.6.1",
    "react-dom": "19.2.1",
    "tinycolor2": "^1.6.0"
  },
  "devDependencies": {
    "@eslint/eslintrc": "^3.3.1",
    "@eslint/js": "^9.39.1",
    "@next/eslint-plugin-next": "^16.0.7",
